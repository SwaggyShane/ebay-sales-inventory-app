# Database
DATABASE_URL=postgresql://user:password@localhost/ebay_sales_local

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_key_here

# eBay API
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_AUTH_TOKEN=your_ebay_auth_token
EBAY_SANDBOX_URL=https://api.sandbox.ebay.com
EBAY_PROD_URL=https://api.ebay.com

# OAuth (for future eBay OAuth flow)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=http://localhost:3001/auth/ebay/callback
